@model web.Models.ChatPageViewModel
@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    /* Override layout for full-width chat */
    .layout { grid-template-columns: 260px 1fr !important; gap: 0 !important; }
    .right-sidebar { display: none !important; }
    .feed { padding: 0 !important; min-height: calc(100vh - 90px); }

    .chat-container {
        display: grid;
        grid-template-columns: 340px 1fr;
        height: calc(100vh - 90px);
        background: var(--card);
        border-radius: 20px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    /* ── Conversation List Panel ── */
    .conv-panel {
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .conv-header {
        padding: 1.5rem 1.2rem 1rem;
        border-bottom: 1px solid var(--border);
    }
    .conv-header h2 {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 1.4rem;
        color: #fff;
        margin-bottom: 1rem;
    }

    .conv-search {
        position: relative;
    }
    .conv-search input {
        width: 100%;
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 0.65rem 1rem 0.65rem 2.6rem;
        color: #fff;
        font-size: 0.85rem;
        transition: var(--transition);
        font-family: 'Inter', sans-serif;
    }
    .conv-search input:focus {
        outline: none;
        border-color: var(--brand);
        box-shadow: 0 0 0 3px rgba(255, 77, 109, 0.1);
    }
    .conv-search input::placeholder { color: var(--text-muted); }
    .conv-search i {
        position: absolute;
        left: 0.9rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .conv-search-results {
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 0; right: 0;
        background: rgba(22, 22, 22, 0.98);
        border: 1px solid var(--border);
        border-radius: 14px;
        max-height: 260px;
        overflow-y: auto;
        z-index: 100;
        display: none;
        backdrop-filter: blur(20px);
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    }
    .conv-search-results.visible { display: block; }

    .search-user-item {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.8rem 1rem;
        cursor: pointer;
        transition: var(--transition);
        text-decoration: none;
        color: inherit;
    }
    .search-user-item:hover { background: rgba(255, 77, 109, 0.08); }
    .search-user-item .user-avatar {
        width: 36px; height: 36px;
        border-radius: 10px;
        object-fit: cover;
        border: 1px solid var(--border);
    }
    .search-user-item .user-initial {
        width: 36px; height: 36px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, rgba(255, 77, 109, 0.15), rgba(167, 139, 250, 0.15));
        border: 1px solid var(--border);
        font-weight: 700; color: var(--brand); font-size: 0.8rem;
    }

    .conv-list {
        flex: 1;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.08) transparent;
    }
    .conv-list::-webkit-scrollbar { width: 4px; }
    .conv-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

    .conv-item {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding: 1rem 1.2rem;
        cursor: pointer;
        transition: var(--transition);
        border-bottom: 1px solid rgba(255,255,255,0.03);
        position: relative;
        text-decoration: none;
        color: inherit;
    }
    .conv-item:hover { background: rgba(255, 255, 255, 0.03); }
    .conv-item.active { background: rgba(255, 77, 109, 0.08); border-left: 3px solid var(--brand); }

    .conv-avatar-wrap {
        position: relative;
        flex-shrink: 0;
    }
    .conv-avatar {
        width: 48px; height: 48px;
        border-radius: 14px;
        object-fit: cover;
        border: 1px solid var(--border);
    }
    .conv-avatar-initial {
        width: 48px; height: 48px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, rgba(255, 77, 109, 0.2), rgba(167, 139, 250, 0.2));
        border: 1px solid var(--border);
        color: var(--brand); font-weight: 800; font-size: 1.1rem;
    }
    .online-dot {
        width: 12px; height: 12px;
        background: #4ade80;
        border: 2px solid var(--dark);
        border-radius: 50%;
        position: absolute;
        bottom: -1px; right: -1px;
        box-shadow: 0 0 8px rgba(74, 222, 128, 0.5);
    }

    .conv-info { flex: 1; min-width: 0; }
    .conv-name {
        font-weight: 700; font-size: 0.92rem; color: #fff;
        margin-bottom: 3px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .conv-preview {
        font-size: 0.8rem; color: var(--text-muted);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .conv-preview.unread { color: #fff; font-weight: 600; }

    .conv-meta { text-align: right; flex-shrink: 0; }
    .conv-time { font-size: 0.7rem; color: var(--text-muted); margin-bottom: 5px; }
    .conv-unread {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 20px; height: 20px; padding: 0 6px;
        background: var(--brand); color: #fff; border-radius: 10px;
        font-size: 0.65rem; font-weight: 800;
        box-shadow: 0 2px 8px var(--brand-glow);
    }

    .conv-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        height: 100%; color: var(--text-muted); padding: 2rem; text-align: center;
    }
    .conv-empty i { font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.4; }

    /* ── Chat Area ── */
    .chat-area {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .chat-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        background: rgba(8, 8, 8, 0.4);
        backdrop-filter: blur(10px);
    }
    .chat-header .conv-avatar { width: 40px; height: 40px; border-radius: 12px; }
    .chat-header .conv-avatar-initial { width: 40px; height: 40px; border-radius: 12px; font-size: 0.95rem; }
    .chat-header-info h3 {
        font-weight: 700; font-size: 0.95rem; color: #fff; margin: 0;
    }
    .chat-header-status {
        font-size: 0.75rem;
        display: flex; align-items: center; gap: 0.4rem;
    }
    .chat-header-status.online { color: #4ade80; }
    .chat-header-status.offline { color: var(--text-muted); }
    .chat-header-status .dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        display: inline-block;
    }
    .chat-header-status.online .dot { background: #4ade80; box-shadow: 0 0 8px rgba(74, 222, 128, 0.4); }
    .chat-header-status.offline .dot { background: var(--text-muted); }

    .chat-header-actions {
        margin-left: auto;
        display: flex; gap: 0.5rem;
    }
    .chat-action-btn {
        width: 36px; height: 36px;
        border-radius: 10px;
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--border);
        color: var(--text-muted);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: var(--transition);
        font-size: 1rem;
    }
    .chat-action-btn:hover { color: #fff; border-color: #666; }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.08) transparent;
    }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

    .msg-group {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        max-width: 70%;
    }
    .msg-group.mine { align-self: flex-end; align-items: flex-end; }
    .msg-group.theirs { align-self: flex-start; align-items: flex-start; }

    .msg-bubble {
        padding: 0.7rem 1.1rem;
        border-radius: 18px;
        font-size: 0.9rem;
        line-height: 1.55;
        word-wrap: break-word;
        animation: msgIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) backwards;
    }
    @@keyframes msgIn { from { opacity: 0; transform: translateY(8px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }

    .msg-group.mine .msg-bubble {
        background: linear-gradient(135deg, var(--brand), #e8476a);
        color: #fff;
        border-bottom-right-radius: 6px;
    }
    .msg-group.theirs .msg-bubble {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid var(--border);
        color: var(--text-main);
        border-bottom-left-radius: 6px;
    }

    .msg-time {
        font-size: 0.65rem;
        color: var(--text-muted);
        padding: 0 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }
    .msg-time .bi-check2-all { color: #60a5fa; font-size: 0.75rem; }

    .typing-indicator {
        align-self: flex-start;
        display: none;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 0;
        color: var(--text-muted);
        font-size: 0.8rem;
    }
    .typing-indicator.visible { display: flex; }
    .typing-dots { display: flex; gap: 3px; }
    .typing-dots span {
        width: 6px; height: 6px;
        background: var(--text-muted);
        border-radius: 50%;
        animation: typingBounce 1.4s infinite ease-in-out;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes typingBounce {
        0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
        40% { transform: translateY(-6px); opacity: 1; }
    }

    .date-separator {
        text-align: center;
        padding: 0.8rem 0;
        position: relative;
    }
    .date-separator span {
        background: rgba(22, 22, 22, 0.9);
        padding: 0.3rem 1rem;
        border-radius: 20px;
        font-size: 0.7rem;
        color: var(--text-muted);
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        border: 1px solid var(--border);
    }

    /* ── Message Input ── */
    .chat-input-area {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: rgba(8, 8, 8, 0.4);
        backdrop-filter: blur(10px);
    }
    .chat-input-row {
        display: flex;
        align-items: flex-end;
        gap: 0.8rem;
    }
    .chat-input {
        flex: 1;
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 0.75rem 1.2rem;
        color: #fff;
        font-size: 0.9rem;
        resize: none;
        max-height: 120px;
        min-height: 44px;
        line-height: 1.5;
        font-family: 'Inter', sans-serif;
        transition: var(--transition);
    }
    .chat-input:focus {
        outline: none;
        border-color: var(--brand);
        box-shadow: 0 0 0 3px rgba(255, 77, 109, 0.1);
    }
    .chat-input::placeholder { color: var(--text-muted); }

    .chat-send-btn {
        width: 44px; height: 44px;
        border-radius: 14px;
        background: var(--brand);
        border: none;
        color: #fff;
        font-size: 1.1rem;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: var(--transition);
        flex-shrink: 0;
    }
    .chat-send-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 20px var(--brand-glow);
    }
    .chat-send-btn:active { transform: scale(0.95); }
    .chat-send-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    /* ── Empty / No Chat State ── */
    .chat-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        text-align: center;
        padding: 3rem;
    }
    .chat-empty-icon {
        width: 100px; height: 100px;
        border-radius: 30px;
        background: linear-gradient(135deg, rgba(255, 77, 109, 0.1), rgba(167, 139, 250, 0.1));
        border: 1px solid var(--border);
        display: flex; align-items: center; justify-content: center;
        font-size: 2.5rem;
        color: var(--brand);
        margin-bottom: 1.5rem;
    }
    .chat-empty h3 {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        color: #fff;
        font-size: 1.4rem;
        margin-bottom: 0.5rem;
    }
    .chat-empty p {
        font-size: 0.9rem;
        color: var(--text-muted);
        max-width: 300px;
        line-height: 1.6;
    }

    /* ── Responsive ── */
    @@media (max-width: 900px) {
        .chat-container { grid-template-columns: 1fr; }
        .conv-panel { display: none; }
        .conv-panel.mobile-show { display: flex; position: absolute; inset: 0; z-index: 10; background: var(--dark); }
    }
</style>
}

<div class="chat-container" id="chatContainer">
    <!-- Conversation List -->
    <div class="conv-panel">
        <div class="conv-header">
            <h2><i class="bi bi-chat-square-heart-fill" style="color:var(--brand); margin-right:0.5rem;"></i>Messages</h2>
            <div class="conv-search">
                <i class="bi bi-search"></i>
                <input type="text"
                       id="chatSearchInput"
                       placeholder="Search people..."
                       autocomplete="off" />
                <div class="conv-search-results" id="chatSearchResults"></div>
            </div>
        </div>

        <div class="conv-list" id="convList">
            @if (!Model.Conversations.Any())
            {
                <div class="conv-empty" id="convEmptyState">
                    <i class="bi bi-chat-left-text"></i>
                    <p style="font-size:0.85rem;">No conversations yet.<br/>Search for someone to start chatting!</p>
                </div>
            }
            else
            {
                @foreach (var c in Model.Conversations)
                {
                    <a href="@Url.Action("Index", "Chat", new { conversationId = c.ConversationId })"
                       class="conv-item @(c.ConversationId == Model.ActiveConversationId ? "active" : "")"
                       data-conversation-id="@c.ConversationId"
                       data-user-id="@c.OtherUserId">
                        <div class="conv-avatar-wrap">
                            @if (!string.IsNullOrEmpty(c.OtherUserAvatar))
                            {
                                <img src="@c.OtherUserAvatar" class="conv-avatar" alt="" />
                            }
                            else
                            {
                                <div class="conv-avatar-initial">@c.OtherUserName[0]</div>
                            }
                            @if (c.IsOnline)
                            {
                                <div class="online-dot"></div>
                            }
                        </div>
                        <div class="conv-info">
                            <div class="conv-name">@c.OtherUserName</div>
                            <div class="conv-preview @(c.UnreadCount > 0 ? "unread" : "")">
                                @(c.LastMessage != null ? (c.LastMessage.Length > 40 ? c.LastMessage[..40] + "…" : c.LastMessage) : "Start a conversation")
                            </div>
                        </div>
                        <div class="conv-meta">
                            <div class="conv-time">@FormatTime(c.LastMessageAt)</div>
                            @if (c.UnreadCount > 0)
                            {
                                <div class="conv-unread">@c.UnreadCount</div>
                            }
                        </div>
                    </a>
                }
            }
        </div>
    </div>

    <!-- Chat Area -->
    <div class="chat-area">
        @if (Model.ActiveConversationId.HasValue)
        {
            <div class="chat-header">
                <div class="conv-avatar-wrap">
                    @if (!string.IsNullOrEmpty(Model.ActiveRecipientAvatar))
                    {
                        <img src="@Model.ActiveRecipientAvatar" class="conv-avatar" alt="" />
                    }
                    else
                    {
                        <div class="conv-avatar-initial">@Model.ActiveRecipientName?[0]</div>
                    }
                    @if (Model.ActiveRecipientOnline)
                    {
                        <div class="online-dot"></div>
                    }
                </div>
                <div class="chat-header-info">
                    <h3>@Model.ActiveRecipientName</h3>
                    <div class="chat-header-status @(Model.ActiveRecipientOnline ? "online" : "offline")">
                        <span class="dot"></span>
                        @(Model.ActiveRecipientOnline ? "Online" : "Offline")
                    </div>
                </div>
                <div class="chat-header-actions">
                    <a href="@Url.Action("Profile", "Home", new { id = Model.ActiveRecipientId })" class="chat-action-btn" title="View Profile">
                        <i class="bi bi-person"></i>
                    </a>
                </div>
            </div>

            <div class="chat-messages" id="chatMessages">
                @{
                    string? lastDate = null;
                }
                @foreach (var msg in Model.Messages)
                {
                    var msgDate = msg.SentAt.ToString("yyyy-MM-dd");
                    if (msgDate != lastDate)
                    {
                        lastDate = msgDate;
                        <div class="date-separator">
                            <span>@FormatDate(msg.SentAt)</span>
                        </div>
                    }
                    <div class="msg-group @(msg.IsMine ? "mine" : "theirs")" data-msg-id="@msg.Id">
                        <div class="msg-bubble">
                            @if (!string.IsNullOrEmpty(msg.MediaUrl))
                            {
                                if (msg.MediaType == "image")
                                {
                                    <div style="margin-bottom:5px;"><img src="@msg.MediaUrl" style="max-width:100%; border-radius:10px; cursor:pointer;" onclick="window.open('@msg.MediaUrl','_blank')" /></div>
                                }
                                else if (msg.MediaType == "video")
                                {
                                    <div style="margin-bottom:5px;"><video src="@msg.MediaUrl" controls style="max-width:100%; border-radius:10px;"></video></div>
                                }
                                else
                                {
                                    <div style="margin-bottom:5px;"><a href="@msg.MediaUrl" target="_blank" style="color:#fff; text-decoration:underline;"><i class="bi bi-file-earmark"></i> Download File</a></div>
                                }
                            }
                            @Html.Raw(msg.Content)
                        </div>
                        <div class="msg-time">
                            @msg.SentAt.ToString("h:mm tt")
                            @if (msg.IsMine)
                            {
                                <i class="bi @(msg.IsRead ? "bi-check2-all" : "bi-check2")"></i>
                            }
                        </div>
                    </div>
                }

                <div class="typing-indicator" id="typingIndicator">
                    <div class="typing-dots">
                        <span></span><span></span><span></span>
                    </div>
                    <span id="typingText">typing...</span>
                </div>
            </div>

            <div class="chat-input-area">
                <input type="file" id="chatFilePicker" style="display:none;" onchange="handleChatFileUpload(this)" />
                <div class="chat-input-row">
                    <button class="chat-action-btn" type="button" onclick="document.getElementById('chatFilePicker').click()" title="Attach file">
                        <i class="bi bi-paperclip"></i>
                    </button>
                    <textarea class="chat-input"
                              id="chatInput"
                              placeholder="Type a message..."
                              rows="1"
                              maxlength="2000"></textarea>
                    <button class="chat-send-btn"
                            id="chatSendBtn"
                            disabled
                            title="Send message">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
                <div id="chatUploadPreview" style="display:none; margin-top:10px; position:relative; width:fit-content;">
                    <img id="chatPreviewImg" style="max-width:100px; border-radius:10px; border:1px solid var(--border);" />
                    <video id="chatPreviewVid" style="max-width:100px; display:none; border-radius:10px; border:1px solid var(--border);"></video>
                    <div id="chatPreviewFile" style="display:none; background:rgba(255,255,255,0.05); padding:8px 12px; border-radius:10px; color:#fff; font-size:0.8rem;">
                        <i class="bi bi-file-earmark"></i> <span id="chatPreviewFileName"></span>
                    </div>
                    <button type="button" onclick="cancelChatUpload()" style="position:absolute; top:-8px; right:-8px; background:var(--brand); border:none; color:#fff; width:20px; height:20px; border-radius:50%; font-size:12px; display:flex; align-items:center; justify-content:center; cursor:pointer;">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="chat-empty">
                <div class="chat-empty-icon">
                    <i class="bi bi-chat-square-heart"></i>
                </div>
                <h3>Your Messages</h3>
                <p>Select a conversation or search for someone to start a new one.</p>
            </div>
        }
    </div>
</div>

@functions {
    string FormatTime(DateTime dt)
    {
        var now = DateTime.UtcNow;
        var diff = now - dt;
        if (diff.TotalMinutes < 1) return "Now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h";
        if (diff.TotalDays < 7) return dt.ToString("ddd");
        return dt.ToString("MMM d");
    }

    string FormatDate(DateTime dt)
    {
        var now = DateTime.UtcNow;
        if (dt.Date == now.Date) return "Today";
        if (dt.Date == now.Date.AddDays(-1)) return "Yesterday";
        return dt.ToString("MMMM d, yyyy");
    }
}

@section Scripts {
<script>
    const currentUserId = '@Model.CurrentUserId';
    const activeConversationId = @(Model.ActiveConversationId?.ToString() ?? "null");
    const activeRecipientId = '@(Model.ActiveRecipientId ?? "")';

    // ── Auto-scroll to bottom ──
    const chatMessages = document.getElementById('chatMessages');
    if (chatMessages) {
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    // ── Textarea auto-resize & send button state ──
    const chatInput = document.getElementById('chatInput');
    const sendBtn = document.getElementById('chatSendBtn');

    if (chatInput) {
        chatInput.addEventListener('input', () => {
            chatInput.style.height = 'auto';
            chatInput.style.height = Math.min(chatInput.scrollHeight, 120) + 'px';
            sendBtn.disabled = !chatInput.value.trim();

            // Typing indicator
            if (activeRecipientId && chatInput.value.trim()) {
                connection.invoke('SendTypingIndicator', activeRecipientId).catch(() => {});
            }
        });

        chatInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
    }

    if (sendBtn) {
        sendBtn.addEventListener('click', () => sendMessage());
    }

    let pendingMedia = null; // { url, type }

    async function handleChatFileUpload(input) {
        const file = input.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append('file', file);
        formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

        try {
            const res = await fetch('/Chat/UploadChatMedia', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.success) {
                pendingMedia = { url: data.url, type: data.type };
                showChatMediaPreview(data.url, data.type, file.name);
                sendBtn.disabled = false;
            }
        } catch (e) {
            showToast('Upload failed', 'bi-exclamation-circle');
        }
    }

    function showChatMediaPreview(url, type, name) {
        const wrap = document.getElementById('chatUploadPreview');
        const img = document.getElementById('chatPreviewImg');
        const vid = document.getElementById('chatPreviewVid');
        const fileDiv = document.getElementById('chatPreviewFile');
        
        wrap.style.display = 'block';
        img.style.display = type === 'image' ? 'block' : 'none';
        vid.style.display = type === 'video' ? 'block' : 'none';
        fileDiv.style.display = type === 'file' ? 'block' : 'none';

        if(type==='image') img.src = url;
        if(type==='video') vid.src = url;
        if(type==='file') document.getElementById('chatPreviewFileName').innerText = name;
    }

    function cancelChatUpload() {
        pendingMedia = null;
        document.getElementById('chatUploadPreview').style.display = 'none';
        document.getElementById('chatFilePicker').value = '';
        if(!chatInput.value.trim()) sendBtn.disabled = true;
    }

    // ── Send Message via SignalR ──
    function sendMessage() {
        const content = chatInput?.value?.trim() || '';
        if (!content && !pendingMedia) return;
        if (!activeRecipientId) return;

        const mediaUrl = pendingMedia?.url || null;
        const mediaType = pendingMedia?.type || null;

        chatInput.value = '';
        chatInput.style.height = 'auto';
        sendBtn.disabled = true;
        cancelChatUpload();

        connection.invoke('SendDirectMessage', activeRecipientId, content, mediaUrl, mediaType).catch(err => {
            console.error('Send failed:', err);
            showToast('Failed to send message', 'bi-exclamation-triangle');
        });
    }

    // ── Receive Messages ──
    connection.on('ReceiveDirectMessage', (data) => {
        if (!activeConversationId && data.conversationId) {
            // Redirect to conversation if we're on the chat page with no active convo
            window.location.href = `/Chat?conversationId=${data.conversationId}`;
            return;
        }

        if (data.conversationId === activeConversationId) {
            appendMessage(data);

            // Mark as read if it's from someone else
            if (data.senderId !== currentUserId) {
                connection.invoke('MarkConversationRead', activeConversationId).catch(() => {});
            }
        } else if (data.senderId !== currentUserId) {
            // Update conversation list badge
            updateConvListItem(data);
        }
    });

    function appendMessage(data) {
        if (!chatMessages) return;

        // Hide typing indicator
        const typing = document.getElementById('typingIndicator');
        if (typing) typing.classList.remove('visible');

        const isMine = data.senderId === currentUserId;
        const time = new Date(data.sentAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });

        const group = document.createElement('div');
        group.className = `msg-group ${isMine ? 'mine' : 'theirs'}`;
        group.dataset.msgId = data.id;
        
        // Use a temporary div to decode content or just trust the SignalR payload if sanitized
        // For SignalR, we'll implement a simple client-side version or fetch formatted from server
        // To keep it simple and consistent with the server-side formatter:
        let mediaHtml = '';
        if (data.mediaUrl) {
            if (data.mediaType === 'image') {
                mediaHtml = `<div style="margin-bottom:5px;"><img src="${data.mediaUrl}" style="max-width:100%; border-radius:10px; cursor:pointer;" onclick="window.open('${data.mediaUrl}','_blank')" /></div>`;
            } else if (data.mediaType === 'video') {
                mediaHtml = `<div style="margin-bottom:5px;"><video src="${data.mediaUrl}" controls style="max-width:100%; border-radius:10px;"></video></div>`;
            } else {
                mediaHtml = `<div style="margin-bottom:5px;"><a href="${data.mediaUrl}" target="_blank" style="color:#fff; text-decoration:underline;"><i class="bi bi-file-earmark"></i> Download File</a></div>`;
            }
        }

        group.innerHTML = `
            <div class="msg-bubble">
                ${mediaHtml}
                ${data.content || ''}
            </div>
            <div class="msg-time">
                ${time}
                ${isMine ? '<i class="bi bi-check2"></i>' : ''}
            </div>
        `;

        // Insert before typing indicator
        if (typing) {
            chatMessages.insertBefore(group, typing);
        } else {
            chatMessages.appendChild(group);
        }

        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function updateConvListItem(data) {
        const item = document.querySelector(`.conv-item[data-conversation-id="${data.conversationId}"]`);
        if (item) {
            const preview = item.querySelector('.conv-preview');
            if (preview) {
                preview.textContent = data.content.length > 40 ? data.content.substring(0, 40) + '…' : data.content;
                preview.classList.add('unread');
            }
            const time = item.querySelector('.conv-time');
            if (time) time.textContent = 'Now';

            // Add or update unread badge
            let badge = item.querySelector('.conv-unread');
            if (badge) {
                badge.textContent = parseInt(badge.textContent) + 1;
            } else {
                const meta = item.querySelector('.conv-meta');
                if (meta) {
                    badge = document.createElement('div');
                    badge.className = 'conv-unread';
                    badge.textContent = '1';
                    meta.appendChild(badge);
                }
            }

            // Move to top
            item.parentNode.prepend(item);
        }
    }

    // ── Typing Indicator ──
    let typingTimeout;
    connection.on('UserTyping', (data) => {
        if (data.userId === activeRecipientId) {
            const indicator = document.getElementById('typingIndicator');
            if (indicator) {
                indicator.classList.add('visible');
                clearTimeout(typingTimeout);
                typingTimeout = setTimeout(() => indicator.classList.remove('visible'), 3000);
                if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;
            }
        }
    });

    // ── Messages Read ──
    connection.on('MessagesRead', (data) => {
        if (data.conversationId === activeConversationId) {
            document.querySelectorAll('.msg-group.mine .bi-check2').forEach(icon => {
                icon.className = 'bi bi-check2-all';
            });
        }
    });

    // ── User Search ──
    const searchInput = document.getElementById('chatSearchInput');
    const searchResults = document.getElementById('chatSearchResults');
    let searchTimeout;

    if (searchInput) {
        searchInput.addEventListener('input', () => {
            clearTimeout(searchTimeout);
            const q = searchInput.value.trim();
            if (q.length < 2) {
                searchResults.classList.remove('visible');
                return;
            }
            searchTimeout = setTimeout(async () => {
                const res = await fetch(`/Chat/SearchUsers?q=${encodeURIComponent(q)}`);
                const users = await res.json();
                if (!users.length) {
                    searchResults.innerHTML = '<div style="padding:1rem;color:var(--text-muted);font-size:0.85rem;text-align:center;">No users found</div>';
                } else {
                    searchResults.innerHTML = users.map(u => `
                        <a href="/Chat?userId=${u.id}" class="search-user-item">
                            ${u.avatar
                                ? `<img src="${u.avatar}" class="user-avatar" alt="" />`
                                : `<div class="user-initial">${u.name[0]}</div>`
                            }
                            <div>
                                <div style="font-weight:700;color:#fff;font-size:0.9rem;">${escapeHtml(u.name)}</div>
                                <div style="font-size:0.75rem;color:${u.isOnline ? '#4ade80' : 'var(--text-muted)'};">
                                    ${u.isOnline ? '● Online' : '○ Offline'}
                                </div>
                            </div>
                        </a>
                    `).join('');
                }
                searchResults.classList.add('visible');
            }, 300);
        });

        // Close search results on click outside
        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.classList.remove('visible');
            }
        });
    }

    // ── Utility ──
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
</script>
}
