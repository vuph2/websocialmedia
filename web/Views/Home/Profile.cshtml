@model web.Models.ProfileViewModel
@{
    ViewData["Title"] = $"{Model.FirstName}'s Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<p hidden id="nexus-view-marker">HOME_PROFILE</p>

@section Styles {
<style>
    .profile-header {
        border-radius: 24px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        display: flex;
        gap: 2.5rem;
        align-items: center;
        background: var(--card);
        border: 1px solid var(--border);
    }

    .profile-avatar-big {
        width: 140px; height: 140px; border-radius: 36px;
        object-fit: cover; border: 4px solid var(--border);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5); flex-shrink: 0;
    }

    .profile-info {
        flex: 1;
        min-width: 0;
    }

    .profile-info h1 {
        font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2.5rem;
        margin: 0 0 0.2rem 0; letter-spacing: -1px;
        word-wrap: break-word;
        word-break: break-word;
        overflow-wrap: break-word;
    }

    .profile-handle { color: var(--text-muted); font-size: 1.1rem; margin-bottom: 1.2rem; display: block; }
    .profile-bio { line-height: 1.6; color: #eee; max-width: 500px; margin-bottom: 1.8rem; }

    .profile-stats { display: flex; gap: 2.5rem; margin-bottom: 2rem; }
    .stat-item { display: flex; flex-direction: column; }
    .stat-item.clickable { cursor: pointer; transition: var(--transition); padding: 0.4rem 0.8rem; margin: -0.4rem -0.8rem; border-radius: 12px; }
    .stat-item.clickable:hover { background: rgba(255, 255, 255, 0.05); }
    .stat-value { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.4rem; color: #fff; }
    .stat-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

    .btn-follow-lg {
        background: var(--brand); color: #fff; border: none; padding: 0.8rem 2.5rem;
        border-radius: 14px; font-weight: 700; cursor: pointer; transition: var(--transition);
        box-shadow: 0 4px 15px var(--brand-glow);
    }
    .btn-follow-lg:hover { transform: translateY(-2px); box-shadow: 0 6px 20px var(--brand-glow); }
    .btn-follow-lg.unfollow { background: rgba(255,255,255,0.05); border: 1px solid var(--border); box-shadow: none; }
    .btn-follow-lg.unfollow:hover { border-color: #ff6b6b; color: #ff6b6b; }

    .section-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.4rem; margin: 3rem 0 1.5rem; }

    /* ── Follow List Modal ── */
    .follow-modal-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(6px);
        z-index: 9000; display: none; align-items: center; justify-content: center;
        animation: fadeIn 0.2s ease;
    }
    .follow-modal-overlay.active { display: flex; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .follow-modal {
        background: var(--card); border: 1px solid var(--border); border-radius: 24px;
        width: 100%; max-width: 460px; max-height: 70vh; display: flex; flex-direction: column;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5); animation: slideUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    @@keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .follow-modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.5rem 1.8rem; border-bottom: 1px solid var(--border);
    }
    .follow-modal-header h3 {
        font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.3rem; margin: 0;
    }
    .follow-modal-close {
        background: none; border: none; color: var(--text-muted); font-size: 1.4rem;
        cursor: pointer; transition: var(--transition); width: 36px; height: 36px;
        display: flex; align-items: center; justify-content: center; border-radius: 10px;
    }
    .follow-modal-close:hover { color: #fff; background: rgba(255,255,255,0.05); }

    .follow-modal-body { overflow-y: auto; padding: 1rem 1.5rem; flex: 1; }

    .follow-user-item {
        display: flex; align-items: center; gap: 1rem; padding: 0.8rem 0.3rem;
        border-bottom: 1px solid var(--border); transition: var(--transition);
    }
    .follow-user-item:last-child { border-bottom: none; }
    .follow-user-item:hover { background: rgba(255,255,255,0.02); border-radius: 12px; }

    .follow-user-avatar {
        width: 44px; height: 44px; border-radius: 14px; object-fit: cover;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, rgba(255, 77, 109, 0.2), rgba(167, 139, 250, 0.2));
        border: 1px solid var(--border); color: var(--brand); font-weight: 800;
        font-size: 1rem; flex-shrink: 0;
    }
    img.follow-user-avatar { background: none; }

    .follow-user-info { flex: 1; min-width: 0; }
    .follow-user-name { font-weight: 700; font-size: 0.95rem; color: #fff; }
    .follow-user-name a { color: #fff; text-decoration: none; }
    .follow-user-name a:hover { color: var(--brand); }
    .follow-user-bio { font-size: 0.8rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .follow-user-btn {
        background: rgba(255,255,255,0.05); border: 1px solid var(--border);
        color: #fff; font-size: 0.8rem; font-weight: 700; padding: 0.4rem 1rem;
        border-radius: 10px; cursor: pointer; transition: var(--transition); white-space: nowrap;
    }
    .follow-user-btn:hover { border-color: var(--brand); color: var(--brand); }
    .follow-user-btn.following { background: var(--brand); border-color: var(--brand); }
    .follow-user-btn.following:hover { background: rgba(255,77,109,0.2); }

    .follow-empty { text-align: center; padding: 3rem 1rem; color: var(--text-muted); }
    .follow-empty i { font-size: 2.5rem; display: block; margin-bottom: 1rem; opacity: 0.4; }

    .follow-loading { text-align: center; padding: 3rem; }
    .follow-loading .spinner {
        width: 28px; height: 28px; border: 3px solid rgba(255,255,255,0.1);
        border-top-color: var(--brand); border-radius: 50%;
        animation: spin 0.8s linear infinite; margin: 0 auto;
    }

    @@media (max-width: 768px) {
        .profile-header { flex-direction: column; text-align: center; }
        .profile-stats { justify-content: center; }
        .follow-modal { margin: 1rem; max-height: 85vh; }
    }
</style>
}

<div class="profile-page">
    <div class="profile-header glass-effect">
        @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
        {
            <img src="@Model.ProfilePictureUrl" class="profile-avatar-big" alt=""/>
        }
        else
        {
            <div class="profile-avatar-big glass-effect" style="display:flex; align-items:center; justify-content:center; font-size:3.5rem; font-family:'Syne';">@Model.FirstName[0]</div>
        }
        
        <div class="profile-info">
            <h1>@Model.FirstName @Model.LastName</h1>
            <span class="profile-handle">@@@Model.Email.Split('@')[0]</span>
            
            <p class="profile-bio">@(string.IsNullOrEmpty(Model.Bio) ? "Explore the Nexus universe." : Model.Bio)</p>
            
            <div class="profile-stats">
                <div class="stat-item">
                    <span class="stat-value">@Model.PostCount</span>
                    <span class="stat-label">Posts</span>
                </div>
                <div class="stat-item clickable" onclick="openFollowModal('followers')">
                    <span class="stat-value" id="stat-followers">@ViewBag.FollowerCount</span>
                    <span class="stat-label">Followers</span>
                </div>
                <div class="stat-item clickable" onclick="openFollowModal('following')">
                    <span class="stat-value" id="stat-following">@ViewBag.FollowingCount</span>
                    <span class="stat-label">Following</span>
                </div>
            </div>

            <div class="profile-actions" id="friendship-actions" style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                @if (Model.UserId != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                {
                    if (Model.FriendshipStatus == "Friends") {
                        <button class="btn-check-friends" style="display:flex; align-items:center; background:var(--card); border:1px solid rgba(74,222,128,0.5); color:#4ade80; box-shadow:none; cursor:default; padding:0.8rem 2.5rem; border-radius:14px; font-weight:700;"><i class="bi bi-check-circle-fill me-2"></i> Friends</button>
                        <button type="button" class="btn-follow-lg unfollow" title="Unfriend" style="padding:0.8rem 1.2rem;" onclick="performFriendshipAction('RemoveFriend', { friendshipId: @Model.FriendshipId, userId: '@Model.UserId' }, this)"><i class="bi bi-person-x-fill"></i></button>
                    } else if (Model.FriendshipStatus == "PendingSent") {
                        <button class="btn-pending-sent" style="display:flex; align-items:center; background:var(--card); border:1px solid var(--border); color:var(--text-muted); box-shadow:none; cursor:default; padding:0.8rem 2.5rem; border-radius:14px; font-weight:700;"><i class="bi bi-clock me-2"></i> Request Sent</button>
                        <button type="button" class="btn-follow-lg unfollow" title="Cancel Request" style="padding:0.8rem 1.2rem;" onclick="performFriendshipAction('RemoveFriend', { friendshipId: @Model.FriendshipId, userId: '@Model.UserId' }, this)"><i class="bi bi-x-lg"></i></button>
                    } else if (Model.FriendshipStatus == "PendingReceived") {
                        <button type="button" class="btn-follow-lg" onclick="performFriendshipAction('AcceptFriend', { friendshipId: @Model.FriendshipId, userId: '@Model.UserId' }, this)"><i class="bi bi-person-check-fill me-2"></i> Accept</button>
                        <button type="button" class="btn-follow-lg unfollow" title="Decline" style="padding:0.8rem 1.2rem;" onclick="performFriendshipAction('DeclineFriend', { friendshipId: @Model.FriendshipId, userId: '@Model.UserId' }, this)"><i class="bi bi-x-lg"></i></button>
                    } else {
                        <button type="button" class="btn-follow-lg" onclick="performFriendshipAction('AddFriend', { targetUserId: '@Model.UserId' }, this)"><i class="bi bi-person-plus-fill me-2"></i> Add Friend</button>
                    }

                    <button class="btn-follow-lg @(ViewBag.IsFollowing ? "unfollow" : "")" style="padding:0.8rem 1.2rem; background:rgba(255,255,255,0.05); border:1px solid var(--border); color:#fff; box-shadow:none;" onclick="toggleFollow('@Model.UserId', this)" title="@(ViewBag.IsFollowing ? "Unfollow" : "Follow")">
                        <i class="bi @(ViewBag.IsFollowing ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                    <button class="btn-follow-lg unfollow" style="padding: 0.8rem 1.2rem;" onclick="location.href='/Chat/Index?userId=@Model.UserId'" title="Chat"><i class="bi bi-chat-dots"></i></button>

                    @if (ViewBag.IsBlockedByMe == true)
                    {
                        <button class="btn-follow-lg unfollow" style="padding:0.8rem 1.2rem;border-color:rgba(239,68,68,0.4);color:#ef4444;" onclick="unblockUserAction('@Model.UserId')" title="Bỏ chặn">
                            <i class="bi bi-slash-circle-fill"></i>
                        </button>
                    }
                    else
                    {
                        <button class="btn-follow-lg unfollow" style="padding:0.8rem 1.2rem;" onclick="blockUserAction('@Model.UserId')" title="Chặn người dùng">
                            <i class="bi bi-slash-circle"></i>
                        </button>
                    }
                }
                else
                {
                    <a href="@Url.Action("Settings", "Home")" class="btn-follow-lg" style="background:rgba(255,255,255,0.05); border:1px solid var(--border); color:#fff; text-decoration:none; display:inline-block; box-shadow:none;">Edit Profile</a>
                }
            </div>
        </div>
    </div>

    <h2 class="section-title">Timeline</h2>
    <div class="profile-posts">
        @if (!Model.Posts.Any())
        {
            <div class="glass-effect" style="padding:4rem; text-align:center; border-radius:24px;">
                <p style="color:var(--text-muted);">No posts shared yet.</p>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_PostList", Model.Posts)
        }
    </div>
</div>

<!-- Follow/Following Modal -->
<div class="follow-modal-overlay" id="followModalOverlay" onclick="if(event.target===this) closeFollowModal()">
    <div class="follow-modal">
        <div class="follow-modal-header">
            <h3 id="followModalTitle">Followers</h3>
            <button class="follow-modal-close" onclick="closeFollowModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="follow-modal-body" id="followModalBody">
            <div class="follow-loading"><div class="spinner"></div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const profileUserId = '@Model.UserId';
        const currentUserId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';

        function updateFriendshipUI(userId, status, friendshipId) {
            if (userId !== profileUserId) return;

            const container = document.getElementById('friendship-actions');
            if (!container) return;

            // Save the follow and chat buttons which are always at the end
            const extraButtons = Array.from(container.querySelectorAll('button')).filter(b => 
                b.onclick && (b.onclick.toString().includes('toggleFollow') || b.onclick.toString().includes('Chat/Index'))
            );

            let html = '';
            if (status === 'Friends') {
                html = `
                    <button class="btn-check-friends" style="display:flex; align-items:center; background:var(--card); border:1px solid rgba(74,222,128,0.5); color:#4ade80; box-shadow:none; cursor:default; padding:0.8rem 2.5rem; border-radius:14px; font-weight:700;"><i class="bi bi-check-circle-fill me-2"></i> Friends</button>
                    <button type="button" class="btn-follow-lg unfollow" title="Unfriend" style="padding:0.8rem 1.2rem;" onclick="performFriendshipAction('RemoveFriend', { friendshipId: ${friendshipId}, userId: '${userId}' }, this)"><i class="bi bi-person-x-fill"></i></button>
                `;
            } else if (status === 'PendingSent') {
                html = `
                    <button class="btn-pending-sent" style="display:flex; align-items:center; background:var(--card); border:1px solid var(--border); color:var(--text-muted); box-shadow:none; cursor:default; padding:0.8rem 2.5rem; border-radius:14px; font-weight:700;"><i class="bi bi-clock me-2"></i> Request Sent</button>
                    <button type="button" class="btn-follow-lg unfollow" title="Cancel Request" style="padding:0.8rem 1.2rem;" onclick="performFriendshipAction('RemoveFriend', { friendshipId: ${friendshipId}, userId: '${userId}' }, this)"><i class="bi bi-x-lg"></i></button>
                `;
            } else if (status === 'PendingReceived') {
                html = `
                    <button type="button" class="btn-follow-lg" onclick="performFriendshipAction('AcceptFriend', { friendshipId: ${friendshipId}, userId: '${userId}' }, this)"><i class="bi bi-person-check-fill me-2"></i> Accept</button>
                    <button type="button" class="btn-follow-lg unfollow" title="Decline" style="padding:0.8rem 1.2rem;" onclick="performFriendshipAction('DeclineFriend', { friendshipId: ${friendshipId}, userId: '${userId}' }, this)"><i class="bi bi-x-lg"></i></button>
                `;
            } else {
                html = `<button type="button" class="btn-follow-lg" onclick="performFriendshipAction('AddFriend', { targetUserId: '${userId}' }, this)"><i class="bi bi-person-plus-fill me-2"></i> Add Friend</button>`;
            }

            container.innerHTML = html;
            extraButtons.forEach(btn => container.appendChild(btn));
        }

        async function toggleLike(postId, btn) {
            btn.style.transform = 'scale(1.2)';
            setTimeout(() => btn.style.transform = 'scale(1)', 150);
            const res  = await fetch('/Home/ToggleLike', {
                method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'},
                body:`postId=${postId}&__RequestVerificationToken=${getToken()}`
            });
            const data = await res.json();
            btn.classList.toggle('liked', data.liked);
            const icon = btn.querySelector('i');
            icon.className = data.liked ? 'bi bi-heart-fill' : 'bi bi-heart';
            const card = document.getElementById(`post-${postId}`);
            const likeSpan = card.querySelector('.reaction-info');
            if (likeSpan) likeSpan.innerHTML = `<i class="bi bi-heart-fill" style="color:var(--brand);"></i> ${data.likeCount}`;
        }
        function toggleComments(postId) {
            document.getElementById(`comments-${postId}`).classList.toggle('open');
        }
        async function sendComment(postId) {
            const input = document.getElementById(`commentInput-${postId}`);
            const content = input.value.trim();
            if(!content) return;
            const res = await fetch('/Home/AddComment', {
                method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'},
                body:`postId=${postId}&content=${encodeURIComponent(content)}&__RequestVerificationToken=${getToken()}`
            });
            const data = await res.json();
            input.value = '';
            const list = document.querySelector(`#comments-${postId} .comments-list`);
            const div = document.createElement('div');
            div.className = 'comment-item';
            div.innerHTML = `<div class="comment-avatar">${data.authorName[0]}</div><div class="comment-bubble"><div class="comment-author">${data.authorName}</div><div class="comment-text">${data.content}</div></div>`;
            list.appendChild(div);
        }
        async function deletePost(postId) {
            if(!confirm('Delete post?')) return;
            const res = await fetch('/Home/DeletePost', {
                method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'},
                body:`postId=${postId}&__RequestVerificationToken=${getToken()}`
            });
            const data = await res.json();
            if(data.success) {
                const el = document.getElementById(`post-${postId}`);
                el.style.opacity = '0';
                setTimeout(() => el.remove(), 300);
            }
        }

        // ── Follow Modal ──
        function openFollowModal(type) {
            const overlay = document.getElementById('followModalOverlay');
            const title = document.getElementById('followModalTitle');
            const body = document.getElementById('followModalBody');

            title.textContent = type === 'followers' ? 'Followers' : 'Following';
            body.innerHTML = '<div class="follow-loading"><div class="spinner"></div></div>';
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';

            const endpoint = type === 'followers' 
                ? `/Home/GetFollowers?userId=${profileUserId}` 
                : `/Home/GetFollowing?userId=${profileUserId}`;

            fetch(endpoint)
                .then(r => r.json())
                .then(users => renderFollowList(users, body))
                .catch(() => { body.innerHTML = '<div class="follow-empty"><i class="bi bi-exclamation-circle"></i>Failed to load</div>'; });
        }

        function closeFollowModal() {
            document.getElementById('followModalOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close on Escape key
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeFollowModal(); });

        function renderFollowList(users, container) {
            if (!users.length) {
                container.innerHTML = '<div class="follow-empty"><i class="bi bi-people"></i>No users yet</div>';
                return;
            }

            container.innerHTML = users.map(u => `
                <div class="follow-user-item" id="follow-item-${u.id}">
                    <a href="/Home/Profile/${u.id}">
                        ${u.avatar 
                            ? `<img src="${u.avatar}" class="follow-user-avatar" alt=""/>` 
                            : `<div class="follow-user-avatar">${u.name[0]}</div>`}
                    </a>
                    <div class="follow-user-info">
                        <div class="follow-user-name"><a href="/Home/Profile/${u.id}">${u.name}</a></div>
                        <div class="follow-user-bio">${u.bio || 'Nexus user'}</div>
                    </div>
                    ${u.isMe ? '' : `
                        <button class="follow-user-btn ${u.isFollowedByMe ? 'following' : ''}" 
                                onclick="modalToggleFollow('${u.id}', this)">
                            ${u.isFollowedByMe ? 'Following' : 'Follow'}
                        </button>
                    `}
                </div>
            `).join('');
        }

        async function modalToggleFollow(userId, btn) {
            btn.style.transform = 'scale(0.95)';
            setTimeout(() => btn.style.transform = 'scale(1)', 100);

            const res = await fetch('/Home/ToggleFollow', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `userId=${userId}&__RequestVerificationToken=${getToken()}`
            });
            const data = await res.json();

            if (data.followed) {
                btn.classList.add('following');
                btn.textContent = 'Following';
            } else {
                btn.classList.remove('following');
                btn.textContent = 'Follow';
            }

            // Update profile page counts
            if (data.followerCount !== undefined) {
                const el = document.getElementById('stat-followers');
                if (el) el.textContent = data.followerCount;
            }
            if (data.followingCount !== undefined) {
                const el = document.getElementById('stat-following');
                if (el) el.textContent = data.followingCount;
            }
        }
    </script>
}
